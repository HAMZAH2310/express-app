<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar">
        <a href="/">Home</a>
        <a href="/project">My Project</a>
        <a href="/contact">Contact</a>
    </nav>

    <div class="container">
        <div class="hero-section text-center">
            <h1 class="page-title">{{message}}</h1>
            <p class="lead-text">{{description}}</p>
        </div>

        <hr class="section-divider">

        <div class="profile-picture">
            <img src="/images/ren.jpg" alt="Profile Picture">
        </div>

        <div class="tech-section">
            <h2 class="section-title text-center">Tech Stack & Tools</h2>
            <div class="tech-grid">
                {{#each techStack}}
                <div class="tech-card">
                    <h3>{{this.name}}</h3>
                    <span class="tech-badge">{{this.category}}</span>
                </div>
                {{/each}}
            </div>
        </div>
    </div>
</body>

</html>