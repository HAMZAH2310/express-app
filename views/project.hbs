<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <nav class="navbar">
        <a href="/">Home</a>
        <a href="/project">My Project</a>
        <a href="/contact">Contact</a>
    </nav>

    <div class="container">
        <h1 class="page-title">{{title}}</h1>
        
        <div class="card-grid">
            {{#each projects}}
            <div class="card">
                <h3>{{this.name}}</h3>
                <p>{{this.description}}</p>
                <span class="badge {{this.statusColor}}">{{this.status}}</span>
            </div>
            {{/each}}
        </div>
    </div>
</body>
</html>