<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar">
        <a href="/">Home</a>
        <a href="/project">My Project</a>
        <a href="/contact">Contact</a>
    </nav>

    <div class="container">
        <div class="text-center">
            <h1 class="page-title">{{title}}</h1>
            <p>Silakan hubungi kami melalui email berikut untuk diskusi lebih lanjut:</p>
            <h3 style="margin-top: 1rem; color: #2563eb;">{{email}}</h3>
        </div>
    </div>

    <div class="container">
        <form action="/contact" method="post">
            <input type="text" name="name" placeholder="Nama Anda" required>
            <input type="email" name="email" placeholder="Email Anda" required>
            <textarea name="message" placeholder="Pesan Anda" rows="5" required></textarea>
            <button type="submit">Kirim Pesan</button>

        </form>
    </div>
</body>

</html>