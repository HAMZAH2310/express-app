<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
    <nav class="navbar">
        <a href="/">Home</a>
        <a href="/project">My Project</a>
        <a href="/contact">Contact</a>
    </nav>

    <div class="container">

        {{#if flash}}
            <div class="alert alert-{{flash.type}}">
                {{flash.message}}
            </div>
        {{/if}}

        <h1 class="page-title">{{title}}</h1>

        <form action="/project" method="post">
            <input type="text" name="projectName" placeholder="Project Name" required>
            <textarea name="projectDescription" placeholder="Deskripsi Project" rows="3" required></textarea>
            <select name="projectStatus">
                <option value="in_progress">Dalam Proses</option>
                <option value="completed">Selesai</option>
            </select>
            <button type="submit">Add Project</button>
        </form>

        <div class="tech-grid">
            {{#each projects}}
            <div class="tech-card">
                <h3>
                    <a href="/project/{{id}}">{{title}}</a>
                </h3>
                <p>{{description}}</p>
                <span class="badge badge-{{statusColor}}">
                    {{#if (eq status "completed")}}Selesai{{else}}Dalam Proses{{/if}}
                </span>

                <a href="/project/{{id}}/edit" class="btn-edit">Edit</a>

                <form action="/project/{{id}}/delete" method="post" class="delete-form">
                    <button type="submit" class="btn-delete">Hapus</button>
                </form>
            </div>
            {{/each}}
        </div>
    </div>
</body>

</html>